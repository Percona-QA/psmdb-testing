      {
        "type": "timeseries",
        "title": "MongoDB QPS (pcsm-source-mongodb)",
        "id": 28,
        "description": "MongoDB operations/sec from PMM exporter for service_name=pcsm-source-mongodb (source node). Excludes command op type.",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "name": "Prometheus"
        },
        "targets": [
          {
            "expr": "sum(rate(mongodb_mongod_op_counters_total{service_name=\"pcsm-source-mongodb\",type!=\"command\"}[5m]) or irate(mongodb_mongod_op_counters_total{service_name=\"pcsm-source-mongodb\",type!=\"command\"}[5m]) or rate(mongodb_op_counters_total{service_name=\"pcsm-source-mongodb\",type!=\"command\"}[5m]) or irate(mongodb_op_counters_total{service_name=\"pcsm-source-mongodb\",type!=\"command\"}[5m]))",
            "legendFormat": "QPS",
            "refId": "A",
            "instant": false
          }
        ],
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom",
            "showLegend": true
          },
          "tooltip": {
            "mode": "multi"
